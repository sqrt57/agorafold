@model IReadOnlyList<ConversationSummaryViewModel>
@{
    ViewData["Title"] = "Inbox";
}

<h1>Inbox</h1>

@if (Model.Count == 0)
{
    <p>No conversations yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var item in Model)
        {
            <a class="list-group-item list-group-item-action" asp-controller="Conversations" asp-action="Details" asp-route-id="@item.Id">
                <div class="d-flex justify-content-between">
                    <strong>@item.ListingTitle</strong>
                    <small class="text-muted">@item.LastMessageAt.ToString("g")</small>
                </div>
                <div class="text-muted">With @item.OtherPartyDisplayName</div>
                @if (item.LastMessagePreview is not null)
                {
                    <div>@(item.IsLastMessageMine ? "You: " : "")@item.LastMessagePreview</div>
                }
            </a>
        }
    </div>
}

@model IReadOnlyList<ConversationMessageViewModel>

@* Appended into #messages (hx-swap="beforeend") by both polling and a successful reply. *@

@if (Model.Count > 0)
{
    <div id="empty-hint" hx-swap-oob="delete"></div>
}

@foreach (var message in Model)
{
    @await Html.PartialAsync("_MessageBubble", message)
}

@if (Model.Count > 0)
{
    <input type="hidden" id="last-message-id" value="@Model[^1].Id" hx-swap-oob="true" />
}

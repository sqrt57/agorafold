@model ListingIndexViewModel

@if (Model.Items.Count == 0)
{
    <p>No listings found.</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col">
                <div class="card h-100">
                    <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.Id">
                        @if (item.ThumbnailUrl is not null)
                        {
                            <img src="@item.ThumbnailUrl" class="card-img-top" alt="@item.Title" style="height:180px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height:180px;">No image</div>
                        }
                    </a>
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.Id">@item.Title</a>
                        </h5>
                        <p class="card-text">@(item.Price.HasValue ? item.Price.Value.ToString("C") : "No price")</p>
                        <p class="card-text"><small class="text-muted">@item.CategoryName</small></p>
                    </div>
                </div>
            </div>
        }
    </div>
}

<nav class="mt-4">
    <ul class="pagination">
        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" href="@Url.Action("Index", new { page = Model.Page - 1, categoryId = Model.CategoryId, searchTerm = Model.SearchTerm })"
               hx-get="@Url.Action("Index", new { page = Model.Page - 1, categoryId = Model.CategoryId, searchTerm = Model.SearchTerm })"
               hx-target="#results" hx-swap="innerHTML" hx-push-url="true">Previous</a>
        </li>
        <li class="page-item disabled"><span class="page-link">Page @Model.Page of @Math.Max(Model.TotalPages, 1)</span></li>
        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" href="@Url.Action("Index", new { page = Model.Page + 1, categoryId = Model.CategoryId, searchTerm = Model.SearchTerm })"
               hx-get="@Url.Action("Index", new { page = Model.Page + 1, categoryId = Model.CategoryId, searchTerm = Model.SearchTerm })"
               hx-target="#results" hx-swap="innerHTML" hx-push-url="true">Next</a>
        </li>
    </ul>
</nav>

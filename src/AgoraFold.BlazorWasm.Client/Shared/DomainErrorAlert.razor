@using AgoraFold.BlazorWasm.Client.Api

@if (Error is not null)
{
    <div class="alert @AlertClass">@Message</div>
}

@code {
    // A plain presentational component, matching BlazorServer's precedent: pages catch
    // ApiNotFoundException/ApiForbiddenException themselves (thrown by ApiClient from 404/403
    // responses) and hand the exception here to render, rather than relying on an ErrorBoundary.
    [Parameter]
    public Exception? Error { get; set; }

    private string AlertClass => Error switch
    {
        ApiNotFoundException => "alert-warning",
        ApiForbiddenException => "alert-danger",
        _ => "alert-danger",
    };

    private string Message => Error switch
    {
        ApiNotFoundException => "That item doesn't exist or was removed.",
        ApiForbiddenException => "You don't have permission to do that.",
        _ => "Something went wrong. Please try again.",
    };
}

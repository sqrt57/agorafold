@if (Errors.Count > 0)
{
    <div class="alert alert-danger">
        <ul class="mb-0">
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<string> Errors { get; set; } = [];
}

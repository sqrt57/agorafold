@page "/Listings/{Id:int}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ListingApiClient ListingApi
@inject ConversationApiClient ConversationApi
@inject NavigationManager Navigation

<DomainErrorAlert Error="_error" />

@if (_listing is not null)
{
    <h1>@_listing.Title</h1>
    <p class="text-muted">@_listing.CategoryName &middot; Posted @_listing.CreatedAt.ToLocalTime().ToString("d")</p>
    <p class="fs-4">@(_listing.Price is null ? "Free" : _listing.Price.Value.ToString("C"))</p>

    @if (_listing.Images.Count > 0)
    {
        <div class="row row-cols-2 row-cols-md-4 g-2 mb-3">
            @foreach (var image in _listing.Images)
            {
                <div class="col"><img src="@image.Url" class="img-fluid rounded" alt="@_listing.Title" /></div>
            }
        </div>
    }

    <p style="white-space: pre-wrap;">@_listing.Description</p>
    <p class="text-muted">Seller: @_listing.OwnerDisplayName</p>

    @if (_listing.IsOwner)
    {
        <a class="btn btn-outline-secondary" href="/Listings/Edit/@_listing.Id">Edit</a>
        <a class="btn btn-outline-danger" href="/Listings/Delete/@_listing.Id">Delete</a>
    }
    else if (_listing.CanMessage)
    {
        <button class="btn btn-primary" @onclick="StartConversationAsync">Message Seller</button>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Exception? _error;
    private ListingDetailResponse? _listing;

    protected override async Task OnParametersSetAsync()
    {
        _error = null;
        _listing = null;

        try
        {
            _listing = await ListingApi.GetDetailAsync(Id);
        }
        catch (ApiNotFoundException ex)
        {
            _error = ex;
        }
    }

    private async Task StartConversationAsync()
    {
        var conversation = await ConversationApi.StartAsync(Id);
        Navigation.NavigateTo($"/Conversations/{conversation.Id}");
    }
}

@page "/Listings/Create"
@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ListingApiClient ListingApi
@inject CategoryApiClient CategoryApi
@inject NavigationManager Navigation

<PageTitle>Post a Listing</PageTitle>
<h1>Post a Listing</h1>
<ErrorList Errors="_errors" />

<EditForm Model="_input" OnValidSubmit="SubmitAsync">
    <DataAnnotationsValidator />
    <div class="mb-3">
        <label class="form-label">Title</label>
        <InputText class="form-control" @bind-Value="_input.Title" />
        <ValidationMessage For="() => _input.Title" class="text-danger" />
    </div>
    <div class="mb-3">
        <label class="form-label">Description</label>
        <InputTextArea class="form-control" rows="5" @bind-Value="_input.Description" />
        <ValidationMessage For="() => _input.Description" class="text-danger" />
    </div>
    <div class="mb-3">
        <label class="form-label">Price</label>
        <InputNumber class="form-control" @bind-Value="_input.Price" />
        <ValidationMessage For="() => _input.Price" class="text-danger" />
    </div>
    <div class="mb-3">
        <label class="form-label">Category</label>
        <CategorySelect Categories="_categories" SelectedCategoryId="_input.CategoryId" SelectedCategoryIdChanged="id => _input.CategoryId = id ?? 0" />
    </div>
    <div class="mb-3">
        <label class="form-label">Images (up to 8, 5 MB each)</label>
        <InputFile OnChange="OnFilesSelected" multiple class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Post Listing</button>
</EditForm>

@code {
    private const long MaxFileSize = 5 * 1024 * 1024;

    private readonly CreateInput _input = new();
    private IReadOnlyList<IBrowserFile> _selectedFiles = [];
    private IReadOnlyList<CategoryResponse> _categories = [];
    private string[] _errors = [];

    protected override async Task OnInitializedAsync()
    {
        _categories = await CategoryApi.GetAllAsync();
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        _selectedFiles = e.GetMultipleFiles(maximumFileCount: 8);
    }

    private async Task SubmitAsync()
    {
        var uploads = new List<ListingFileUpload>();
        foreach (var file in _selectedFiles)
        {
            var stream = new MemoryStream();
            await file.OpenReadStream(MaxFileSize).CopyToAsync(stream);
            stream.Position = 0;
            uploads.Add(new ListingFileUpload(file.Name, file.ContentType, stream));
        }

        ListingDetailResponse listing;
        try
        {
            listing = await ListingApi.CreateAsync(_input.Title, _input.Description, _input.Price, _input.CategoryId, uploads);
        }
        catch (ApiValidationException ex)
        {
            _errors = ex.Errors.ToArray();
            return;
        }

        if (listing.ImageErrors is { Count: > 0 })
        {
            // The listing itself was already created - land on Edit so the image upload can be
            // retried without losing the listing, instead of silently dropping the images.
            Navigation.NavigateTo($"/Listings/Edit/{listing.Id}");
            return;
        }

        Navigation.NavigateTo($"/Listings/{listing.Id}");
    }

    private sealed class CreateInput
    {
        [Required, StringLength(200)]
        public string Title { get; set; } = "";
        [Required, StringLength(4000)]
        public string Description { get; set; } = "";
        [Range(0, 100_000_000)]
        public decimal? Price { get; set; }
        [Range(1, int.MaxValue, ErrorMessage = "Please choose a category.")]
        public int CategoryId { get; set; }
    }
}

@page "/Listings/Edit/{Id:int}"
@attribute [Authorize]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject ListingApiClient ListingApi
@inject CategoryApiClient CategoryApi
@inject NavigationManager Navigation

<DomainErrorAlert Error="_error" />

@if (_input is not null)
{
    <h1>Edit Listing</h1>

    <ErrorList Errors="_errors" />

    <EditForm Model="_input" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label class="form-label">Title</label>
            <InputText class="form-control" @bind-Value="_input.Title" />
            <ValidationMessage For="() => _input.Title" class="text-danger" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputTextArea class="form-control" rows="5" @bind-Value="_input.Description" />
            <ValidationMessage For="() => _input.Description" class="text-danger" />
        </div>
        <div class="mb-3">
            <label class="form-label">Price</label>
            <InputNumber class="form-control" @bind-Value="_input.Price" />
            <ValidationMessage For="() => _input.Price" class="text-danger" />
        </div>
        <div class="mb-3">
            <label class="form-label">Category</label>
            <CategorySelect Categories="_categories" SelectedCategoryId="_input.CategoryId" SelectedCategoryIdChanged="id => _input.CategoryId = id ?? 0" />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
    </EditForm>

    <hr />

    <h2 class="h5">Images</h2>
    <ErrorList Errors="_imageErrors" />
    <ImageGallery Images="_images" OnDelete="DeleteImageAsync" />
    <InputFile OnChange="AddImagesAsync" multiple class="form-control" />
}

@code {
    private const long MaxFileSize = 5 * 1024 * 1024;

    [Parameter]
    public int Id { get; set; }

    private Exception? _error;
    private EditInput? _input;
    private List<ImageGallery.ImageEntry> _images = [];
    private IReadOnlyList<CategoryResponse> _categories = [];
    private string[] _errors = [];
    private string[] _imageErrors = [];

    protected override async Task OnParametersSetAsync()
    {
        _error = null;
        _input = null;

        try
        {
            await LoadAsync();
        }
        catch (Exception ex) when (ex is ApiNotFoundException or ApiForbiddenException)
        {
            _error = ex;
        }
    }

    private async Task LoadAsync()
    {
        var listing = await ListingApi.GetDetailAsync(Id);
        if (!listing.IsOwner)
        {
            throw new ApiForbiddenException();
        }

        _categories = await CategoryApi.GetAllAsync();

        _input = new EditInput
        {
            Title = listing.Title,
            Description = listing.Description,
            Price = listing.Price,
            CategoryId = listing.CategoryId,
        };
        _images = listing.Images.Select(i => new ImageGallery.ImageEntry(i.Id, i.Url)).ToList();
    }

    private async Task SaveAsync()
    {
        try
        {
            await ListingApi.UpdateAsync(Id, new ListingUpdateRequest(_input!.Title, _input.Description, _input.Price, _input.CategoryId));
            Navigation.NavigateTo($"/Listings/{Id}");
        }
        catch (ApiValidationException ex)
        {
            _errors = ex.Errors.ToArray();
        }
    }

    private async Task AddImagesAsync(InputFileChangeEventArgs e)
    {
        var uploads = new List<ListingFileUpload>();
        foreach (var file in e.GetMultipleFiles(maximumFileCount: 8))
        {
            var stream = new MemoryStream();
            await file.OpenReadStream(MaxFileSize).CopyToAsync(stream);
            stream.Position = 0;
            uploads.Add(new ListingFileUpload(file.Name, file.ContentType, stream));
        }

        try
        {
            await ListingApi.AddImagesAsync(Id, uploads);
            _imageErrors = [];
            await LoadAsync();
        }
        catch (ApiValidationException ex)
        {
            _imageErrors = ex.Errors.ToArray();
        }
    }

    private async Task DeleteImageAsync(int imageId)
    {
        await ListingApi.DeleteImageAsync(Id, imageId);
        await LoadAsync();
    }

    private sealed class EditInput
    {
        [Required, StringLength(200)]
        public string Title { get; set; } = "";

        [Required, StringLength(4000)]
        public string Description { get; set; } = "";

        [Range(0, 100_000_000)]
        public decimal? Price { get; set; }

        [Range(1, int.MaxValue, ErrorMessage = "Please choose a category.")]
        public int CategoryId { get; set; }
    }
}

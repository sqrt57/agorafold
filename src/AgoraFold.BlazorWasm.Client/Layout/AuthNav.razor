@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject AccountApiClient AccountApi
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

@* A small interactive island embedded in the otherwise-static MainLayout: the nav needs live
   AuthorizeView state and a clickable Logout button, neither of which work in a static component.
   MainLayout itself can't be made interactive as a whole - it would have to receive @Body (a
   RenderFragment) as a parameter crossing the static-to-interactive boundary, which Blazor
   rejects since RenderFragment delegates aren't serializable. Because this is the same
   InteractiveWebAssembly render mode as every page, it shares one WASM runtime/DI scope per page
   load with whichever page is showing, so MarkAuthenticated/MarkLoggedOut calls from either side
   are visible to both. *@

<ul class="navbar-nav flex-grow-1">
    <li class="nav-item"><a class="nav-link" href="/">Browse</a></li>
    <AuthorizeView>
        <Authorized>
            <li class="nav-item"><a class="nav-link" href="/Listings/Create">Post a Listing</a></li>
            <li class="nav-item"><a class="nav-link" href="/Listings/Mine">My Listings</a></li>
            <li class="nav-item"><a class="nav-link" href="/Conversations">Inbox</a></li>
        </Authorized>
    </AuthorizeView>
</ul>
<AuthorizeView>
    <Authorized>
        <ul class="navbar-nav">
            <li class="nav-item"><span class="nav-link">Hi, @context.User.Identity!.Name!</span></li>
            <li class="nav-item">
                <button type="button" class="nav-link btn btn-link" @onclick="LogoutAsync">Logout</button>
            </li>
        </ul>
    </Authorized>
    <NotAuthorized>
        <ul class="navbar-nav">
            <li class="nav-item"><a class="nav-link" href="/Account/Login">Login</a></li>
            <li class="nav-item"><a class="nav-link" href="/Account/Register">Register</a></li>
        </ul>
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task LogoutAsync()
    {
        await AccountApi.LogoutAsync();
        ((CookieAuthenticationStateProvider)AuthProvider).MarkLoggedOut();
        Navigation.NavigateTo("/");
    }
}
